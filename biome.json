{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "extends": ["@nacal-tools/biome-config/biome.json"],
  "files": {
    "includes": ["src/**", "data/**", "*.json"]
  },
  "overrides": [
    {
      "includes": ["data/**"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          }
        }
      }
    }
  ]
}
